from pathlib import Path


def test_hydra_config_files_exist() -> None:
    root = Path(__file__).resolve().parents[1]
    assert (root / "configs" / "config.yaml").exists()
    assert (root / "configs" / "model" / "sentence_transformer.yaml").exists()
    assert (root / "configs" / "eval" / "smoke_metric.yaml").exists()


def test_extended_config_groups_exist() -> None:
    root = Path(__file__).resolve().parents[1]
    assert (root / "configs" / "dataset" / "retrieval_synthetic.yaml").exists()
    assert (root / "configs" / "dataset" / "sts_synthetic.yaml").exists()
    assert (root / "configs" / "compression" / "identity.yaml").exists()
    assert (root / "configs" / "compression" / "truncate.yaml").exists()
    assert (root / "configs" / "compression" / "scalar_int8.yaml").exists()
    assert (root / "configs" / "compression" / "binary.yaml").exists()
    assert (root / "configs" / "compression" / "product_quantize.yaml").exists()
    assert (root / "configs" / "profiling" / "default.yaml").exists()
    assert (root / "configs" / "experiment" / "pareto.yaml").exists()
